# Copy to `.env` and edit.
# Local dev: pydantic-settings reads this file on startup.
# docker compose: this same file is consumed by compose variable substitution
# and the values are forwarded to the container via the `environment:` block.

# Host interface to bind.
PANEL_HOST=0.0.0.0

# Port the app listens on. Under docker compose this is also the host publish port.
PANEL_PORT=5000

# Session signing key. Generate with `python -c "import secrets; print(secrets.token_hex(32))"`.
# If unset, a random key is generated per-process and sessions are invalidated on restart.
SECRET_KEY=

# Where data.json + ssl_temp/ live. Defaults to the repo root locally, /app/data in Docker.
# DATA_DIR=

# Override the assets dir (static/templates/translations). Rarely needed.
# ASSETS_DIR=
